# ManuMaestro Environment Variables
# Copy this file to .env and fill in your values

# Database Connection
DATABASE_URL="postgresql://username:password@host:port/manumaestro_db?schema=public"

# Product Database Connection (existing products table = pricelab_db, read-only)
PRODUCT_DB_URL="postgresql://username:password@host:port/product_db?schema=public"

# DataBridge DB (databridge_db, read-only) — Dashboard pipeline L30/L90 (Wisersell raw_orders)
DATABRIDGE_DB_URL="postgresql://username:password@host:port/databridge_db?schema=public"

# CargoLens DB (cargolens_db, read-only) — Veeqo etiket kıyas paneli (rate_cards/us_shipments)
CARGOLENS_DB_URL="postgresql://username:password@host:port/cargolens_db?schema=public"

# DataBridge servis API'si (Veeqo/Wisersell proxy + dış kapatma)
DATABRIDGE_API_URL="http://localhost:3008"
DATABRIDGE_INTERNAL_API_KEY="databridge-internal-api-key"

# Application
NODE_ENV="development"
PORT=3000

# Süper-admin allowlist (virgülle ayrılmış e-posta). Kritik aksiyonlar bununla sınırlı.
SUPER_ADMIN_EMAILS="ersoy@iwaconcept.com.tr"

# Internal/cron endpoint token'ları
# MANU_INTERNAL_API_KEY: /api/siparis/check-cancellations (sunucu cron) header'ı
MANU_INTERNAL_API_KEY="generate-with-openssl-rand"
# INTERNAL_CLEANUP_TOKEN: /api/internal/labels/cleanup (Bearer) — yoksa SSO-admin fallback
# INTERNAL_CLEANUP_TOKEN="generate-with-openssl-rand"

# Wisersell sipariş otomatik onayı (true/false)
WISERSELL_AUTO_APPROVE="false"

# Etiket PDF/PNG yükleme kök dizini (varsayılan: uploads/labels)
# LABEL_UPLOAD_ROOT="/var/www/manumaestro/uploads/labels"

# SSO Configuration (Server-side)
SSO_URL="https://apps.iwa.web.tr"
SSO_APP_CODE="manumaestro"

# StockPulse service token (sadece /api/production-suggestions/sync için).
# Aynı değer StockPulse .env'inde de olmalı. uuid-v4 öneriyoruz.
# STOCKPULSE_SERVICE_TOKEN="generate-with-uuidgen-or-openssl-rand"

# SSO Configuration (Client-side)
NEXT_PUBLIC_SSO_URL="https://apps.iwa.web.tr"
NEXT_PUBLIC_SSO_APP_CODE="manumaestro"

# Next.js
NEXT_PUBLIC_APP_NAME="ManuMaestro"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Sentry (opsiyonel — DSN yoksa SDK no-op çalışır)
# Hesap açılınca https://sentry.io/settings/[org]/projects/[proj]/keys/ adresinden alınır.
# SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"
# SENTRY_ENV="production"
# NEXT_PUBLIC_SENTRY_ENV="production"
# SENTRY_DEBUG="false"
# /api/sentry-verify endpoint'i için token (test amaçlı):
# SENTRY_VERIFY_TOKEN="generate-with-openssl-rand"
# Source-map upload için (deploy.yml'de Actions secret olarak ekle):
# SENTRY_ORG="iwa"
# SENTRY_PROJECT="manumaestro"
# SENTRY_AUTH_TOKEN="sntrys_xxx"
