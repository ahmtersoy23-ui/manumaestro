// ManuMaestro - Production Request Management System
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(OPERATOR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  permissions               UserMarketplacePermission[]
  categoryPermissions       UserCategoryPermission[]
  stockPermission           UserStockPermission?
  orderPermission           UserOrderPermission?
  shipmentPermissions       UserShipmentPermission[]
  requests                  ProductionRequest[]
  decidedSuggestions        ProductionSuggestion[]
  createdMarketplaces       Marketplace[]               @relation("CreatedBy")
  auditLogs                 AuditLog[]
  monthlyCapacityUpdates    MonthlyCapacity[]           @relation("MonthlyCapacityUpdatedBy")

  @@index([role])
  @@index([isActive])
  @@map("users")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// ============================================
// MARKETPLACE MANAGEMENT
// ============================================

model Marketplace {
  id              String          @id @default(uuid())
  name            String // "Amazon US", "Wayfair UK", "Custom Market"
  code            String          @unique // "AMZN_US", "WAYFAIR_UK", "CUSTOM_01"
  marketplaceType MarketplaceType
  region          String // "US", "EU", "UK", "CA", "AU", "ZA", "NL", "TR", "Custom"
  isCustom        Boolean         @default(false)
  isActive        Boolean         @default(true)
  colorTag        String? // Hex color for UI
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdById     String?

  // Relations
  createdBy     User?                       @relation("CreatedBy", fields: [createdById], references: [id])
  permissions   UserMarketplacePermission[]
  requests      ProductionRequest[]
  suggestions   ProductionSuggestion[]
  priorities    MarketplacePriority[]
  shippingRoute ShippingRoute?

  @@index([isActive, name])
  @@index([createdById])
  @@map("marketplaces")
}

enum MarketplaceType {
  AMAZON
  WAYFAIR
  TAKEALOT
  BOL
  TRENDYOL
  ETSY
  CUSTOM
  OTHER
}

// ============================================
// USER PERMISSIONS
// ============================================

model UserMarketplacePermission {
  id            String   @id @default(uuid())
  userId        String
  marketplaceId String
  canView       Boolean  @default(true)
  canEdit       Boolean  @default(true)
  createdAt     DateTime @default(now())

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([userId, marketplaceId])
  @@index([userId])
  @@index([marketplaceId])
  @@map("user_marketplace_permissions")
}

model UserCategoryPermission {
  userId   String
  category String // ProductionRequest.productCategory değeriyle eşleşir
  canView  Boolean @default(true)
  canEdit  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("user_category_permissions")
}

// ============================================
// PRODUCT REFERENCE (From existing DB)
// ============================================
// Note: This connects to existing products table in another database
// We'll use views or direct queries for this

// ============================================
// PRODUCTION REQUESTS
// ============================================

model ProductionRequest {
  id                String          @id @default(uuid())
  iwasku            String // Reference to products.iwasku
  productName       String // Cached from products
  productCategory   String // Cached from products
  productSize       Float? // Cached from products - desi (volumetric size)
  marketplaceId     String
  quantity          Int
  producedQuantity  Int? // @deprecated — MonthSnapshot.produced tek kaynak. İleride kaldırılacak.
  requestDate       DateTime        @default(now()) // Entry date (today)
  productionMonth   String // Production month in YYYY-MM format (e.g., "2026-03")
  priority          RequestPriority @default(MEDIUM)
  status            RequestStatus   @default(REQUESTED)
  workflowStage     WorkflowStage? // For furniture category workflow tracking
  entryType         EntryType
  recommendedDestination String? @db.VarChar(10) // Sevkiyat hedefi: US_FBA/NJ_DEPO/CG_DEPO/UK_FBA/UK_DEPO/EU_FBA/NL_DEPO/CA_FBA/AU_FBA. StockPulse sync ile yazılır; null ise pipeline endpoint runtime hesaplar.
  notes             String? // Operator notes
  manufacturerNotes String? // Manufacturer production notes
  enteredById       String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id])
  enteredBy   User        @relation(fields: [enteredById], references: [id])

  @@index([iwasku])
  @@index([marketplaceId])
  @@index([requestDate])
  @@index([productionMonth])
  @@index([status])
  @@index([workflowStage])
  @@index([enteredById])
  @@index([createdAt])
  @@index([productCategory])
  @@index([productCategory, workflowStage])
  @@index([priority])
  @@index([productCategory, productionMonth])
  @@index([marketplaceId, productionMonth])
  @@index([status, productionMonth])
  @@index([productionMonth, iwasku])
  @@map("production_requests")
}

enum RequestPriority {
  HIGH
  MEDIUM
  LOW
}

enum RequestStatus {
  REQUESTED
  IN_PRODUCTION
  PARTIALLY_PRODUCED
  COMPLETED
  CANCELLED
}

enum EntryType {
  MANUAL
  EXCEL
  STOCKPULSE
}

// ============================================
// PRODUCTION SUGGESTIONS (StockPulse → ManuMaestro köprüsü, V2 pilot)
// StockPulse günlük tavsiyelerini PENDING olarak yazar; operatör kabul/red eder.
// Kabul edilince ProductionRequest oluşur (entryType=STOCKPULSE).
// ============================================

model ProductionSuggestion {
  id                String           @id @default(uuid())
  iwasku            String
  productName       String
  productCategory   String
  productSize       Float?           // desi
  marketplaceId     String
  productionMonth   String           // "YYYY-MM"
  suggestedQty      Int              // StockPulse planned_qty (ham)
  formulaVersion    String           // "v4" | "v4D" | "v1"
  reasoning         String?          // selectModel autoReasoning
  l30               Int
  l90               Int
  l180              Int
  status            SuggestionStatus @default(PENDING)
  acceptedRequestId String?          // ProductionRequest.id (kabul edilirse)
  syncedAt          DateTime         @default(now())
  decidedAt         DateTime?
  decidedById       String?

  marketplace Marketplace @relation(fields: [marketplaceId], references: [id])
  decidedBy   User?       @relation(fields: [decidedById], references: [id])

  @@unique([iwasku, marketplaceId, productionMonth])
  @@index([status, productionMonth])
  @@index([marketplaceId, status])
  @@map("production_suggestions")
}

enum SuggestionStatus {
  PENDING     // Yeni geldi, karar bekliyor
  ACCEPTED    // ProductionRequest yaratıldı
  DISMISSED   // Operatör reddetti
  EXPIRED     // 30+ gün karar verilmedi
}

enum WorkflowStage {
  REQUESTED // Initial request received
  CUTTING // Material cutting stage
  ASSEMBLY // Assembly/construction stage
  QUALITY_CHECK // Quality control
  PACKAGING // Packaging stage
  READY_TO_SHIP // Ready for shipment
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id          String      @id @default(uuid())
  userId      String
  userName    String // Cached for performance
  userEmail   String // Cached for performance
  action      AuditAction
  entityType  String? // e.g., "ProductionRequest", "Marketplace"
  entityId    String? // ID of the affected entity
  description String // Human-readable description
  metadata    Json? // Additional data (old/new values, etc.)
  ipAddress   String?
  createdAt   DateTime    @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE_REQUEST
  UPDATE_REQUEST
  DELETE_REQUEST
  CREATE_MARKETPLACE
  UPDATE_MARKETPLACE
  DELETE_MARKETPLACE
  UPDATE_PRODUCTION
  LOGIN
  LOGOUT
  BULK_UPLOAD
  EXPORT_DATA
  MONTH_CLOSE
  UPDATE_STOCK
  ACCESS_DENIED
  ROUTE_TO_SHIPMENT
  CREATE_ORDER
  APPROVE_ORDER
  CANCEL_ORDER
  DELETE_ORDER
  CLOSE_ORDER
  LABEL_ORDER
  CANCEL_LABEL
}

// ============================================
// SHIPMENT PERMISSIONS
// ============================================

model UserShipmentPermission {
  id             String       @id @default(uuid())
  userId         String
  destinationTab String // "US", "UK", "EU", "NL", "AU", "ZA" veya "*" (hepsi)
  role           ShipmentRole @default(VIEWER)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, destinationTab])
  @@index([userId])
  @@map("user_shipment_permissions")
}

enum ShipmentRole {
  VIEWER // Sadece goruntuleme
  ROUTER // Talep yonlendirme + silme + FBA isaretleme (pazar yeri sorumlusu)
  PACKER // Koli olusturma + check + gonder (depo elemani)
  MANAGER // Hepsi (sevkiyat olusturma dahil)
}

// ============================================
// WAREHOUSE STOCK
// ============================================

model UserStockPermission {
  userId  String  @unique
  canView Boolean @default(true)
  canEdit Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stock_permissions")
}

// Sipariş board'una özel kademeli izin (shelf/depo izinlerinden BAĞIMSIZ).
// Kümülatif merdiven: APPROVER < CREATOR < FULL. SSO admin → kod tarafında FULL sayılır.
model UserOrderPermission {
  userId String          @unique
  level  OrderBoardLevel @default(NONE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_order_permissions")
}

enum OrderBoardLevel {
  NONE // Sadece görüntüleme
  APPROVER // + Onayla / Kapat / Listeden Düş / CG-tracking-export rutinleri
  CREATOR // + Manuel Giriş
  FULL // + Veeqo Etiket Al / Manuel Sil / Açığa Al / Etiketi İptal
}

model WarehouseProduct {
  id        String   @id @default(uuid())
  iwasku    String   @unique
  eskiStok  Int      @default(0) // Başlangıç stoğu
  ilaveStok Int      @default(0) // Düzeltme / ilave
  cikis     Int      @default(0) // Gönderilen (pozitif saklanır, mevcut'tan çıkarılır)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weeklyEntries WarehouseWeekly[]

  @@map("warehouse_products")
}

model WarehouseWeekly {
  id          String   @id @default(uuid())
  iwasku      String
  weekStart   DateTime @db.Date // Haftanın Pazartesi günü
  quantity    Int      @default(0) // O hafta miktar
  type        String   @default("PRODUCTION") // PRODUCTION veya SHIPMENT
  enteredById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product WarehouseProduct @relation(fields: [iwasku], references: [iwasku], onDelete: Cascade)

  @@unique([iwasku, weekStart, type])
  @@index([iwasku])
  @@map("warehouse_weekly")
}

model MonthSnapshot {
  id             String   @id @default(uuid())
  month          String
  iwasku         String
  totalRequested Int
  warehouseStock Int
  netProduction  Int
  produced       Int      @default(0) // Üretici girişi (ürün bazlı, tek değer)
  createdAt      DateTime @default(now())

  @@unique([month, iwasku])
  @@index([month])
  @@map("month_snapshots")
}

// ============================================
// SEASONAL STOCK MANAGEMENT
// ============================================

model StockPool {
  id            String     @id @default(uuid())
  name          String // "Sezon Q4 2026", "Sezon Q1 2027"
  code          String     @unique // "SZN-Q4-2026", "SZN-Q1-2027"
  poolType      PoolType
  targetQuarter String? // "Q4-2026", "Q1-2027"
  status        PoolStatus @default(ACTIVE)

  productionStart DateTime?
  targetShipDate  DateTime?

  totalTargetDesi  Float?
  totalTargetUnits Int?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reserves StockReserve[]

  @@index([status])
  @@map("stock_pools")
}

model StockReserve {
  id               String        @id @default(uuid())
  poolId           String
  iwasku           String
  targetQuantity   Int
  targetDesi       Float?
  desiPerUnit      Float? // DB cache: import anındaki birim desi. UI pricelab.products'tan canlı override eder, allocator cache'i kullanır.
  initialStock     Int           @default(0) // Depo başlangıç stoğu (mark-stock ile tek seferlik)
  producedQuantity Int           @default(0) // Sezon boyunca yeni üretim (haftalık girişlerden)
  shippedQuantity  Int           @default(0)
  status           ReserveStatus @default(PLANNED)
  destination      String? // "US", "EU", "UK", "NL", "AU", "ZA"
  category         String? // Kategori cache (allocator için)
  marketplaceSplit Json? // {"US": 120, "EU": 80, "UK": 45}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pool        StockPool           @relation(fields: [poolId], references: [id], onDelete: Cascade)
  allocations MonthlyAllocation[]

  @@unique([poolId, iwasku])
  @@index([iwasku])
  @@index([status])
  @@map("stock_reserves")
}

model MonthlyAllocation {
  id          String  @id @default(uuid())
  reserveId   String
  month       String // "2026-04", "2026-05"
  plannedQty  Int
  plannedDesi Float?
  actualQty   Int     @default(0)
  locked      Boolean @default(false) // true = production started, allocation frozen

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reserve StockReserve @relation(fields: [reserveId], references: [id], onDelete: Cascade)

  @@unique([reserveId, month])
  @@index([month])
  @@map("monthly_allocations")
}

enum PoolType {
  SEASONAL
  ROUTINE
}

enum PoolStatus {
  ACTIVE
  RELEASING
  COMPLETED
  CANCELLED
}

enum ReserveStatus {
  PLANNED
  PRODUCING
  STOCKED
  RELEASING
  SHIPPED
  CANCELLED
}

// ============================================
// MARKETPLACE PRIORITY (Waterfall Completion)
// ============================================

model MarketplacePriority {
  id            String @id @default(uuid())
  month         String // "2026-04"
  marketplaceId String
  priority      Int // 1 = en yüksek

  createdAt DateTime @default(now())

  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([month, marketplaceId])
  @@index([month])
  @@map("marketplace_priorities")
}

// ============================================
// SHIPPING MANAGEMENT
// ============================================

model ShippingRoute {
  id             String  @id @default(uuid())
  marketplaceId  String  @unique
  destinationTab String // "US", "UK", "EU", "NL", "AU", "ZA"
  shippingMethod String // "sea", "road", "air"
  leadTimeDays   Int?
  notes          String?

  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@map("shipping_routes")
}

model Shipment {
  id             String @id @default(uuid())
  name           String // "US-2026-08-01", "EU-TIR-2026-10-05"
  destinationTab String // "US", "UK", "EU", "NL", "AU", "ZA"
  shippingMethod String // "sea", "road", "air"

  plannedDate DateTime?
  actualDate  DateTime?
  etaDate     DateTime?

  status ShipmentStatus @default(PLANNING)

  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items      ShipmentItem[]
  boxes      ShipmentBox[]
  containers ShipmentContainer[]

  @@index([destinationTab])
  @@index([status])
  @@map("shipments")
}

model ShipmentItem {
  id                  String    @id @default(uuid())
  shipmentId          String
  iwasku              String
  quantity            Int
  desi                Float?
  marketplaceId       String?
  reserveId           String?
  productionRequestId String? // Yönlendirilen ProductionRequest bağlantısı
  packed              Boolean   @default(false) // Depo: hazırlandı/paketlendi
  labelPrintedAt      DateTime? // EAN ürün etiketi basıldı (null = basılmadı); depo görsel takibi
  sentAt              DateTime? // Gönderildi tarihi (null = bekleyen)
  fnsku               String? // Manuel FNSKU girişi (sku_master'da yoksa)
  recommendedDestination String? @db.VarChar(10) // Son sevkiyat hedefi: US_FBA/NJ_DEPO/CG_DEPO/UK_FBA/UK_DEPO/EU_FBA/NL_DEPO/CA_FBA/AU_FBA/ZA_TAKEALOT. Karma sevkiyat içinde item-level destinasyon.

  createdAt DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([iwasku])
  @@index([productionRequestId])
  @@map("shipment_items")
}

model ShipmentBox {
  id              String   @id @default(uuid())
  shipmentId      String
  shipmentItemId  String? // null: üretim dışı ek ürün
  boxNumber       String // "69-0001", "69-1001"
  iwasku          String?
  fnsku           String?
  productName     String?
  productCategory String?
  marketplaceCode String?
  destination     String   @default("DEPO") // "FBA" veya "DEPO"
  quantity        Int      @default(1)
  width           Float? // cm
  height          Float? // cm
  depth           Float? // cm
  weight          Float? // kg
  labelPrinted    Boolean  @default(false)
  createdAt       DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([boxNumber])
  @@map("shipment_boxes")
}

// Depo (NJ_DEPO/CG_DEPO) konsolidasyon birimi: tek seviye KOLI veya PALET,
// içinde FARKLI ürünler (karışık). FBA tek-SKU ShipmentBox'tan ayrı.
// Varışta (Gemi 71 sonrası fazı) satırlar tekil ShelfStock'a patlatılacak.
model ShipmentContainer {
  id           String   @id @default(uuid())
  shipmentId   String
  type         String // "KOLI" | "PALET"
  code         String // oto-numara: "72-K01" / "72-P02"
  width        Float? // cm
  height       Float? // cm
  depth        Float? // cm
  weight       Float? // kg
  labelPrinted Boolean  @default(false)
  arrivedAt    DateTime? // Varışta (DELIVERED) Fairfield POOL'una patlatıldı — idempotency; null = henüz patlamadı
  createdAt    DateTime @default(now())

  shipment Shipment                @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  lines    ShipmentContainerLine[]

  @@index([shipmentId])
  @@map("shipment_containers")
}

model ShipmentContainerLine {
  id             String @id @default(uuid())
  containerId    String
  shipmentItemId String // hangi ShipmentItem'dan (kalan miktar takibi için)
  iwasku         String // display/label kopyası
  quantity       Int

  container ShipmentContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([containerId])
  @@index([shipmentItemId])
  @@map("shipment_container_lines")
}

model ShipmentBoxArchive {
  id              String   @id @default(uuid())
  shipmentId      String
  shipmentName    String // "Gemi 69"
  destinationTab  String // "US", "EU"
  shippingMethod  String // "sea", "road", "air"
  boxNumber       String
  iwasku          String?
  fnsku           String?
  productName     String?
  productCategory String?
  marketplaceCode String?
  destination     String // "FBA" / "DEPO"
  quantity        Int
  width           Float?
  height          Float?
  depth           Float?
  weight          Float?
  closedAt        DateTime
  createdAt       DateTime @default(now())

  @@index([shipmentId])
  @@index([shipmentName])
  @@index([iwasku])
  @@index([closedAt])
  @@map("shipment_box_archive")
}

enum ShipmentStatus {
  PLANNING
  LOADING
  IN_TRANSIT
  DELIVERED
}

// ============================================
// WAREHOUSE — SHELF / RACK MANAGEMENT (Lite WMS)
// ============================================
// Üç depo (ANKARA, NJ, SHOWROOM) için raf-bazlı izleme.
// - ANKARA: TOTALS_PRIMARY (WarehouseProduct ana doğru, raf bir kırılım)
// - NJ / SHOWROOM: SHELF_PRIMARY (toplamlar raftan türetilir, run-time aggregation)

model Warehouse {
  code      String    @id // "ANKARA" | "NJ" | "SHOWROOM"
  name      String
  region    String // "TR" | "US"
  isActive  Boolean   @default(true)
  stockMode StockMode

  shelves Shelf[]

  @@map("warehouses")
}

enum StockMode {
  TOTALS_PRIMARY // Ankara
  SHELF_PRIMARY // NJ / Showroom
}

model Shelf {
  id            String    @id @default(uuid())
  warehouseCode String
  code          String // "H1-B", "M5-A1" — serbest format
  shelfType     ShelfType @default(NORMAL)
  isActive      Boolean   @default(true)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  warehouse        Warehouse        @relation(fields: [warehouseCode], references: [code], onDelete: Restrict)
  stocks           ShelfStock[]
  boxes            ShelfBox[]
  cycleCountTasks  CycleCountTask[]

  @@unique([warehouseCode, code])
  @@index([warehouseCode, shelfType])
  @@map("shelves")
}

enum ShelfType {
  POOL // Havuz raf — sevkiyat varışı buraya düşer, manuel girişler buraya
  TEMP // Geçici raf
  NORMAL // Normal raf
}

// Rafta tekil/loose ürün
model ShelfStock {
  id            String   @id @default(uuid())
  warehouseCode String
  shelfId       String
  iwasku        String
  quantity      Int      @default(0)
  reservedQty   Int      @default(0) // DRAFT outbound'larda rezerve edilmiş
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  shelf Shelf @relation(fields: [shelfId], references: [id], onDelete: Cascade)

  @@unique([shelfId, iwasku])
  @@index([warehouseCode, iwasku])
  @@map("shelf_stock")
}

// Rafta mühürlü/yarı-açık koli (NJ + Showroom; sevkiyattan veya manuel girişten)
model ShelfBox {
  id              String    @id @default(uuid())
  warehouseCode   String
  shelfId         String
  shipmentBoxId   String?   @unique // ShipmentBox referansı (manuel girişlerde de bağlı)
  boxNumber       String // ShipmentBox.boxNumber kopyası — display + arama
  iwasku          String
  fnsku           String?
  marketplaceCode String?
  destination     String    @default("DEPO") // "FBA" / "DEPO"
  quantity        Int // anlık (kısmi çıkış sonrası azalır)
  reservedQty     Int       @default(0)
  status          BoxStatus @default(SEALED)
  arrivedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shelf Shelf @relation(fields: [shelfId], references: [id], onDelete: Cascade)

  @@index([warehouseCode, iwasku])
  @@index([warehouseCode, status])
  @@index([boxNumber])
  @@map("shelf_boxes")
}

enum BoxStatus {
  SEALED // Mühürlü, hiç dokunulmadı
  PARTIAL // Kısmen alındı (BOX_BREAK)
  EMPTY // Tüm içerik çıkarıldı
}

// Tüm raf hareketleri — audit + undo
model ShelfMovement {
  id            String       @id @default(uuid())
  warehouseCode String
  type          MovementType
  fromShelfId   String?
  toShelfId     String?
  iwasku        String?
  quantity      Int?
  shelfBoxId    String? // koli işlemi ise
  refType       String? // "OUTBOUND_ORDER" / "SHIPMENT" / "MANUAL_BOX" / "FBA_PICKUP"
  refId         String?
  userId        String
  notes         String?
  createdAt     DateTime     @default(now())

  // Self-relation: undo desteği
  reverseOfId String?
  reverseOf   ShelfMovement?  @relation("ShelfMovementReversal", fields: [reverseOfId], references: [id])
  reversedBy  ShelfMovement[] @relation("ShelfMovementReversal")

  @@index([warehouseCode, createdAt])
  @@index([type])
  @@index([reverseOfId])
  @@index([userId])
  @@index([fromShelfId])
  @@index([toShelfId])
  @@map("shelf_movements")
}

enum MovementType {
  INBOUND_FROM_SHIPMENT // Sevkiyat DELIVERED → POOL
  INBOUND_MANUAL // Manuel koli ekleme
  TRANSFER // Aynı depo içi raf-rafa
  CROSS_WAREHOUSE_TRANSFER // NJ ↔ Showroom (POOL/TEMP'e)
  BOX_OPEN // Koli tamamen açıldı
  BOX_BREAK // Koliden kısmen alındı
  OUTBOUND // Sipariş çıkışı
  ADJUSTMENT // Cycle count sapması veya manuel düzeltme (gerekçe zorunlu)
  REVERSAL // Başka hareketin geri alınması
}

// Sipariş çıkışı (NJ + Showroom): SINGLE veya FBA_PICKUP
model OutboundOrder {
  id              String         @id @default(uuid())
  warehouseCode   String // "NJ" | "SHOWROOM"
  orderType       OrderType
  marketplaceCode String // SINGLE'da seçilen; FBA_PICKUP'da "AMZN_US" sabit
  orderNumber     String // SINGLE: order#; FBA_PICKUP: appointment/pickup ID
  // Kanal sipariş no'su (paket fişindeki no, ör. "S_IWAUS22055"). MANUAL'da = orderNumber;
  // WISERSELL_AUTO'da label_prefix+label_no (orderNumber ise Wisersell iç kodu, ör. 51199).
  // Çift kayıt guard'ı bununla eşleştirir (aynı sipariş, farklı numara/kaynak).
  channelOrderNumber String?
  description     String?
  addressNote     String? // Adres ve serbest açıklama — SINGLE entry sırasında
  status          OutboundStatus @default(DRAFT)
  source          OutboundSource @default(MANUAL) // MANUAL = elle; WISERSELL_AUTO = Sipariş otomasyonu
  wisersellOrderId Int?          @unique // Wisersell internal order id (otomasyon) — idempotency + external-close anahtarı
  wisersellOrderItemIds Int[]    // Wisersell orderitem id'leri (onayda candidate'tan yazılır) — üretim durumu (Beklemede/Teslim/Yeni) yazmak için. Çıkış candidate'tan saatler sonra → id'yi burada tut.
  wisersellReadyAt DateTime?     // Wisersell "Kargoya Hazır" (status/update) başarıyla yazıldıysa; null = ready-pending (retry)
  wisersellClosedAt DateTime?    // external-close başarıyla yazıldıysa (Kapandı)
  manualTracking  String?        // CG/etiketsiz akış: operatörün Wayfair MCF raporundan elle girdiği tracking (SHIPPING etiketi yok)
  cgExportedAt    DateTime?      // CG (CastleGate) MCF Excel'i alındıysa — tekrar export'a girmesin (çift MCF önleme)
  amazonCancelledAt DateTime?    // SP-API canlı kontrol: Amazon'da Canceled tespit edildi (Ama_US). Board'da "İptal (Amazon)" rozeti + operatör "Listeden Düş".
  createdById     String
  createdAt       DateTime       @default(now())
  shippedById     String?
  shippedAt       DateTime?
  updatedAt       DateTime       @updatedAt

  items  OutboundOrderItem[]
  labels OrderLabel[]

  @@unique([warehouseCode, marketplaceCode, orderNumber])
  @@index([warehouseCode, status])
  @@index([createdById])
  @@index([shippedById])
  @@index([channelOrderNumber])
  @@map("outbound_orders")
}

model OutboundOrderItem {
  id              String  @id @default(uuid())
  outboundOrderId String
  iwasku          String
  quantity        Int
  shelfId         String? // (legacy / single-source pick) tekil rafından çıkıyorsa
  shelfBoxId      String? // (legacy / single-source pick) koliden çıkıyorsa

  order       OutboundOrder                  @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  allocations OutboundOrderItemAllocation[]

  @@index([outboundOrderId])
  @@index([iwasku])
  @@map("outbound_order_items")
}

// Bir OutboundOrderItem'ın stoğa bağlanmasının ayrıntısı.
// Aynı iwasku birden fazla rafa/koli'ye bölünebilir; her allocation tek bir
// kaynağa (shelfId VEYA shelfBoxId) işaret eder. Çıkış (SHIPPED) anında
// bu satırlar kullanılarak ShelfStock/ShelfBox'tan düşülür.
model OutboundOrderItemAllocation {
  id          String @id @default(uuid())
  orderItemId String
  shelfId     String? // tekil rafından
  shelfBoxId  String? // koliden
  quantity    Int

  orderItem OutboundOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([shelfId])
  @@index([shelfBoxId])
  @@map("outbound_order_item_allocations")
}

// Mobilya siparişi onayında "TR" seçilince: aday Sipariş board'dan GİZLENİR.
// CANCELLED DEĞİL, Wisersell'e dokunulmaz (TR sevkiyatı orada ayrıca yapılır).
// wisersell_order_id bazlı yerel işaret; board onayBekliyor'dan eler.
model OrderTrDismissed {
  wisersellOrderId Int      @id
  dismissedAt      DateTime @default(now())
  dismissedById    String
  recipientName    String?  // görsel/iz amaçlı kopya
  orderCode        String?

  @@map("order_tr_dismissed")
}

enum OrderType {
  SINGLE // Tekil sipariş — raf+koli karışık seçim, kısmi koli kırma destekli
  FBA_PICKUP // Amazon FBA pick-up — koli bazlı, tam koli (kısmi yok)
}

enum OutboundStatus {
  DRAFT // Hazırlanıyor, rezerve var, stok düşmedi
  SHIPPED // Onaylandı ve gönderildi, stok düştü
  CANCELLED // İptal edildi, rezerveler serbest
}

enum OutboundSource {
  MANUAL // Operatör elle oluşturdu (mevcut per-warehouse akış)
  WISERSELL_AUTO // Sipariş otomasyonu (Wisersell aday → onay) oluşturdu
}

// Depo bazlı yetki — UserShipmentPermission paterniyle aynı (FK yok, "*" wildcard saklanabilir)
model UserShelfPermission {
  id            String    @id @default(uuid())
  userId        String
  warehouseCode String // "ANKARA" | "NJ" | "SHOWROOM" veya "*" tüm depolar
  role          ShelfRole @default(VIEWER)
  createdAt     DateTime  @default(now())

  @@unique([userId, warehouseCode])
  @@index([userId])
  @@map("user_shelf_permissions")
}

enum ShelfRole {
  VIEWER // Sadece görüntüleme
  PACKER // Sipariş yaratır/düzenler (DRAFT). Sevk edemez.
  OPERATOR // Raflar arası transfer, koli aç/parçala, yeni raf, manuel inbound
  MANAGER // OPERATOR + sipariş onaylama (DRAFT→SHIPPED), undo, raf silme
  ADMIN // Hepsi + depo ayarı, izin yönetimi
}

// CSV seed/import sırasında iwasku eşlemesi bulunamayan satırlar
// Admin'in mapping ekranından elle çözeceği bekleme kuyruğu
model UnmatchedSeedRow {
  id             String          @id @default(uuid())
  warehouseCode  String // "NJ" / "ANKARA" / "SHOWROOM"
  source         String // "CSV_SEED" / "MANUAL" / "IMPORT"
  rawLookup      String // CSV'deki orijinal "fnsku" kolon değeri
  description    String?
  shelfCode      String // "H1-B" — RESOLVED sırasında shelfId resolve
  boxNumber      String? // null = loose / dolu = mühürlü koli
  quantity       Int
  status         UnmatchedStatus @default(PENDING)
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedIwasku String?
  resolutionType ResolutionType?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([warehouseCode, status])
  @@index([rawLookup])
  @@map("unmatched_seed_rows")
}

enum UnmatchedStatus {
  PENDING // Bekliyor, admin atamamış
  RESOLVED // Admin atadı, ana stok'a yazıldı
  SKIPPED // Admin "atla" dedi (#N/A vb.)
}

enum ResolutionType {
  SKU_MASTER // sku_master.iwasku ile bulundu
  PRODUCTS // products.product_sku doğrudan iwasku
  LOCAL_ALIAS // Lokal alias (manumaestro_db) — ileride
  PSEUDO // Yeni pseudo-iwasku (streç vb. yardımcı malzeme) — planlanacak
  SKIP // Atlandı
}

// Sipariş bazlı etiket yüklemeleri (kargo PDF, FNSKU PDF, vb.)
// FBA_PICKUP'ta FNSKU koliye özel olabilir → shipmentBoxId opsiyonel.
model OrderLabel {
  id              String         @id @default(uuid())
  outboundOrderId String
  shipmentBoxId   String? // FNSKU spesifik koliye bağlıysa (FBA_PICKUP)
  type            OrderLabelType
  fileName        String // Yüklenen orijinal dosya adı
  storagePath     String // {UPLOAD_ROOT}/labels/{orderId}/{id}.pdf
  mimeType        String // application/pdf, image/png, image/jpeg
  fileSize        Int // bytes
  uploadedById    String
  uploadedAt      DateTime       @default(now())
  printedAt       DateTime?
  printedById     String?
  notes           String?
  trackingNumber  String? // Kargo tracking no — etiket arşivlense bile saklanır
  veeqoShipmentId String? // Veeqo remote_shipment_id (iade/iptal anahtarı — DELETE .../shipments/{id})
  cost            Decimal?  @db.Decimal(10, 2) // Etiket bedeli (Veeqo book total_charge) — mutabakat/export
  costCurrency    String?   // Bedel para birimi (ör. USD)
  archivedAt      DateTime? // Fiziksel dosya silindi (tracking ref. kaldı)

  outboundOrder OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)

  @@index([outboundOrderId, type])
  @@index([shipmentBoxId])
  @@index([archivedAt])
  @@index([uploadedById])
  @@index([printedById])
  @@map("order_labels")
}

enum OrderLabelType {
  SHIPPING // Kargo etiketi (Aras, UPS, FedEx, USPS, DHL vb.)
  FNSKU // Amazon FNSKU etiketi (FBA_PICKUP)
  OTHER // Ticari fatura, packing list, diğer
}

// Cycle count (devirli sayım) görevleri — ABC sınıfına göre periyodik
// (A: ayda 1, B: 3 ayda 1, C: 6 ayda 1). Sayım blind: sistem qty
// kullanıcıya gösterilmez, sayılan miktar ile karşılaştırılır.
model CycleCountTask {
  id            String           @id @default(uuid())
  warehouseCode String
  shelfId       String
  abcClass      String? // A | B | C — generator sırasında set edilir
  status        CycleCountStatus @default(PENDING)
  scheduledFor  DateTime         @default(now())
  toleranceQty  Int              @default(0) // A=0, B=1, C=2
  assignedToId  String?
  startedAt     DateTime?
  startedById   String?
  completedAt   DateTime?
  completedById String?
  notes         String?
  createdAt     DateTime         @default(now())

  shelf Shelf            @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  items CycleCountItem[]

  @@index([warehouseCode, status])
  @@index([shelfId])
  @@index([assignedToId])
  @@index([completedById])
  @@map("cycle_count_tasks")
}

model CycleCountItem {
  id           String                @id @default(uuid())
  taskId       String
  iwasku       String
  source       CycleCountItemSource // STOCK | BOX
  shelfStockId String?
  shelfBoxId   String?
  systemQty    Int // task başlatıldığında snapshot
  countedQty   Int? // kullanıcının girdiği (blind)
  diffQty      Int? // counted - system (item commit anında set)
  resolution   CycleCountResolution?
  resolvedById String?
  resolvedAt   DateTime?

  task CycleCountTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([iwasku])
  @@map("cycle_count_items")
}

enum CycleCountStatus {
  PENDING // Generate edildi, başlanmadı
  IN_PROGRESS // Sayım yapılıyor (blind giriş)
  COMPLETED // Sayıldı, tüm fark tolerans içinde
  DISCREPANCY // Sayıldı, en az bir kalemde fark > tolerance — manager review
}

enum CycleCountItemSource {
  STOCK // ShelfStock kaydı
  BOX // ShelfBox kaydı
}

enum CycleCountResolution {
  ACCEPT // Kullanıcı kabul etti, adjust yapıldı
  INVESTIGATE // İncelemeye alındı, henüz adjust yok
  IGNORE // Yok say (hata, çift sayım vb.)
}

// =============================================================================
// PRODUCT SERIAL COUNTER — üretim etiketi için iwasku-bazlı seri numarası sayacı
// =============================================================================
// Üretim etiketinde basılan IWASKU-XXXXXX serisinin per-SKU counter'ı.
// Atomic increment için ON CONFLICT UPSERT pattern'i kullanılır (lib/serial/generate.ts).
// İleride SwiftStock ile senkronize edilebilir; şimdilik ManuMaestro tek otorite.
model ProductSerialCounter {
  iwasku     String   @id
  lastSerial Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("product_serial_counters")
}

// Aylık üretim kapasitesi — sezon allocator + ileride üst sınır kriteri için.
// İleride: günlük desi × çalışma günü = ayın tavan üretim desisi.
// Sezonsal SKU önerileri bu rakamı aşamayacak şekilde önceliklendirilir.
model MonthlyCapacity {
  id           String   @id @default(uuid())
  month        String   @unique // 'YYYY-MM'
  dailyDesi    Int      @default(500) // günlük üretim kapasitesi (desi)
  workingDays  Int      @default(22)  // ayın çalışma günü sayısı
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  updatedById  String?
  updatedBy    User?    @relation("MonthlyCapacityUpdatedBy", fields: [updatedById], references: [id])

  @@map("monthly_capacity")
}

// Somerset→Fairfield transfer önerisini "yok say" işaretleri.
// dismissedAt, o ürünün son tetikleyici olayından (Fairfield çıkışı / koli kırma)
// sonra ise öneri gizlenir. Yeni bir olay olursa lastEvent ileri kayar ve öneri
// tekrar belirir → kalıcı gizlemenin "bir daha görünmez" riski yok. FK yok
// (UserShelfPermission pattern'i).
model TransferDismissal {
  id            String   @id @default(uuid())
  iwasku        String   @unique
  dismissedAt   DateTime @default(now())
  dismissedById String

  @@map("transfer_dismissals")
}

// ============================================
// STOK PUSH (kanal-bazli, genisletilebilir)
// ============================================
// Pazar yeri listing'lerine otomatik available push. Ilk kanal: AMAZON_US (FBM,
// SP-API fulfillment_availability). Sonra SHOPIFY_US / WALMART_US ayni model + UI
// sekmesi + adaptorle eklenir (rework yok). 3 kova: default = STANDARD (sabit
// settings.standardQty) · STOCK = US depo available bazli (CG MDN/Shukran + NJ +
// SHOWROOM toplami, yuzde + sifirlama esigi) · ZERO = discontinued, hep 0. Config'te
// OLMAYAN her iwasku STANDARD. ManuMaestro hesaplar, DataBridge ile API'ye yazar.
// FBA'ya dokunulmaz.
enum StockPushMode {
  STOCK
  ZERO
}

model StockPushConfig {
  id         String        @id @default(uuid())
  channel    String        @default("AMAZON_US")
  iwasku     String
  mode       StockPushMode
  warehouses String[]      @default([]) // STOCK icin: CG_MDN, CG_SHUKRAN, NJ, SHOWROOM
  percent    Int           @default(100) // STOCK icin yuzde (0-100)
  floorX     Int           @default(0) // STOCK: base available < floorX ise 0 push (alt sinir)
  handlingDays Int?        // Amazon handling time (lead_time_to_ship_max_days); null=gönderme (Amazon default)
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([channel, iwasku])
  @@index([channel])
  @@map("stock_push_config")
}

model StockPushSettings {
  channel              String   @id @default("AMAZON_US")
  standardQty          Int      @default(11)
  standardHandlingDays Int?     // Amazon: kuralsızlara basılacak default handling time; null=gönderme
  enabled              Boolean  @default(false)
  dryRun               Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  @@map("stock_push_settings")
}

// Son push edilen adet — diff icin (sadece degisen SKU adaptore gider).
model StockPushState {
  channel        String
  marketplaceSku String
  iwasku         String
  lastQty        Int
  lastHandling   Int?     // son push edilen handling time (diff icin)
  lastPushedAt   DateTime @default(now())

  @@id([channel, marketplaceSku])
  @@index([channel, iwasku])
  @@map("stock_push_state")
}
